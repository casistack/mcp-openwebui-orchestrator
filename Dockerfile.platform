# Multi-stage build for MCP Platform (backend + web)
#
# Stage 1 (base): shared Node + pnpm setup
# Stage 2 (deps): install ALL deps - native addons compile/download here
# Stage 3 (builder): build TypeScript / SvelteKit from source
# Stage 4 (prod-deps): clean prod-only install + native addon from deps
# Stage 5 (runtime): minimal image with only built output + prod deps

FROM node:22-slim AS base
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate
WORKDIR /app

# ---------------------------------------------------------------------------
# Stage 2: Install ALL dependencies (native addons compile here via prebuild)
# ---------------------------------------------------------------------------
FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json tsconfig.base.json ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/backend/package.json packages/backend/
COPY packages/web/package.json packages/web/
COPY packages/cli/package.json packages/cli/
RUN pnpm install --frozen-lockfile

# ---------------------------------------------------------------------------
# Stage 3: Build all packages (TypeScript, SvelteKit, etc.)
# ---------------------------------------------------------------------------
FROM deps AS builder
COPY packages/shared/ packages/shared/
COPY packages/db/ packages/db/
COPY packages/backend/ packages/backend/
COPY packages/web/ packages/web/
COPY packages/cli/ packages/cli/
RUN pnpm turbo run build

# ---------------------------------------------------------------------------
# Stage 4: Production-only deps (skip ALL lifecycle scripts to avoid husky)
# Then copy pre-built better-sqlite3 native addon from deps stage.
# ---------------------------------------------------------------------------
FROM base AS prod-deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/backend/package.json packages/backend/
COPY packages/cli/package.json packages/cli/
# Web has no runtime deps but pnpm workspace requires its package.json
COPY packages/web/package.json packages/web/
RUN pnpm install --frozen-lockfile --prod --ignore-scripts

# better-sqlite3 native addon: --ignore-scripts skipped prebuild-install above,
# so we copy the compiled build/ directory from the deps stage directly.
ARG BETTER_SQLITE3_VERSION=11.10.0
COPY --from=deps /app/node_modules/.pnpm/better-sqlite3@${BETTER_SQLITE3_VERSION}/node_modules/better-sqlite3/build \
    /app/node_modules/.pnpm/better-sqlite3@${BETTER_SQLITE3_VERSION}/node_modules/better-sqlite3/build/

# ---------------------------------------------------------------------------
# Stage 5: Production runtime (minimal, no build tools, no pnpm)
# ---------------------------------------------------------------------------
FROM node:22-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && apt-get upgrade -y \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy workspace config
COPY --from=builder /app/package.json /app/pnpm-workspace.yaml ./
COPY --from=builder /app/packages/shared/package.json packages/shared/
COPY --from=builder /app/packages/db/package.json packages/db/
COPY --from=builder /app/packages/backend/package.json packages/backend/
COPY --from=builder /app/packages/cli/package.json packages/cli/

# Copy production node_modules (with pre-built native addon)
COPY --from=prod-deps /app/node_modules node_modules/
COPY --from=prod-deps /app/packages/shared/node_modules packages/shared/node_modules/
COPY --from=prod-deps /app/packages/db/node_modules packages/db/node_modules/
COPY --from=prod-deps /app/packages/backend/node_modules packages/backend/node_modules/
COPY --from=prod-deps /app/packages/cli/node_modules packages/cli/node_modules/

# Copy built output
COPY --from=builder /app/packages/shared/dist packages/shared/dist/
COPY --from=builder /app/packages/db/dist packages/db/dist/
COPY --from=builder /app/packages/db/src/schema packages/db/src/schema/
COPY --from=builder /app/packages/db/src/migrations packages/db/src/migrations/
COPY --from=builder /app/packages/backend/dist packages/backend/dist/
COPY --from=builder /app/packages/cli/dist packages/cli/dist/
COPY --from=builder /app/packages/web/build packages/web/build/

# Create non-root user
RUN groupadd -r mcpgroup && \
    useradd -r -g mcpgroup -m -s /bin/bash mcpuser && \
    mkdir -p /data /config /app/tmp && \
    chown -R mcpuser:mcpgroup /app /data /config

ENV NODE_ENV=production
ENV DATABASE_URL=/data/mcp-platform.db
ENV MANAGER_PORT=3001
ENV CLAUDE_CONFIG_PATH=/config/claude_desktop_config.json

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:3001/api/auth/ok || exit 1

USER mcpuser

CMD ["node", "packages/backend/dist/server.js"]
